# Klarsa Core — environment template (STAGING)
# =============================================================================
# This is a TEMPLATE with PLACEHOLDERS ONLY. Copy it to `.env.local` and fill in
# real values there. `.env.local` is git-ignored and must NEVER be committed.
#
#   cp .env.local.example .env.local
#
# Rules:
#   - NEVER commit a real `.env.local` (no URLs, keys, refs, passwords).
#   - The SERVICE ROLE key is SERVER-ONLY: it bypasses Row Level Security.
#     Never expose it to the browser, never prefix it with NEXT_PUBLIC_,
#     never log it.
#   - Only NEXT_PUBLIC_* values are safe to ship to the client.
#   - Use a STAGING project here. NO production data in staging.
# =============================================================================

# Supabase project URL (e.g. https://<project-ref>.supabase.co)
# Public/client-safe.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key. Client-safe; RLS still applies to it.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key. SERVER-ONLY. Bypasses RLS — treat as a top secret.
# Never NEXT_PUBLIC_, never sent to the browser, never logged.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project ref (the <project-ref> part of the URL). Used by the CLI.
SUPABASE_PROJECT_REF=

# Klarsa environment marker. Keep "staging" until production is approved.
KLARSA_ENV=staging
