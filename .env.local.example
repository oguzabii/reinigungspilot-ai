# Klarsa Core — environment template (STAGING)
# =============================================================================
# This is a TEMPLATE with PLACEHOLDERS ONLY. Copy it to `.env.local` and fill in
# real values there. `.env.local` is git-ignored and must NEVER be committed.
#
#   cp .env.local.example .env.local
#
# Rules:
#   - NEVER commit a real `.env.local` (no URLs, keys, refs, passwords).
#   - The SERVICE ROLE key is SERVER-ONLY: it bypasses Row Level Security.
#     Never expose it to the browser, never prefix it with NEXT_PUBLIC_,
#     never log it.
#   - Only NEXT_PUBLIC_* values are safe to ship to the client.
#   - Use a STAGING project here. NO production data in staging.
# =============================================================================

# Supabase project URL (e.g. https://<project-ref>.supabase.co)
# Public/client-safe.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key. Client-safe; RLS still applies to it.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key. SERVER-ONLY. Bypasses RLS — treat as a top secret.
# Never NEXT_PUBLIC_, never sent to the browser, never logged.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project ref (the <project-ref> part of the URL). Used by the CLI.
SUPABASE_PROJECT_REF=

# Klarsa environment marker. Keep "staging" until production is approved.
KLARSA_ENV=staging

# -----------------------------------------------------------------------------
# Automatic Discovery (v0.5.2) — OPTIONAL, owner-configured.
# -----------------------------------------------------------------------------
# Google Places API key for the OFFICIAL Places Text Search adapter
# (lib/discovery/google-places.ts). SERVER-ONLY — never NEXT_PUBLIC_, never sent
# to the browser, never logged, never committed. If unset, Automatic Discovery
# shows "not configured" and the app keeps working. Owner/admin-triggered only;
# no cron. Official API only — NO scraping of Google Maps pages/HTML.
GOOGLE_PLACES_API_KEY=

# Shared secret for the PREPARED discovery/signal cron endpoint
# (app/api/autopilot/discovery-cron/route.ts). SERVER-ONLY. If unset, the
# endpoint returns 404 (invisible). Even when set, the endpoint is DISABLED by
# design and performs NO writes — scheduled tenant writes would need a
# service-role identity, which is intentionally not used. There is no vercel.json
# cron entry, so nothing is scheduled.
CRON_SECRET=

# Baugesuche Zürich signal source (v0.5.4; official CSV supported v0.5.4.1).
# OPTIONAL, owner-configured. SERVER-ONLY. URL of a *validated* OFFICIAL building-
# permit / construction-project open-data feed. Supports official CSV (auto-
# detected) AND JSON/GeoJSON. The validated Kanton Zürich CSV is, for example:
#   https://daten.statistik.zh.ch/ogd/daten/ressourcen/KTZH_00002982_00006183.csv
# If unset, the Baugesuche adapter shows "not configured" and the app keeps
# working. Official CSV/JSON body ONLY — NO website scraping, NO HTML/PDF parsing,
# NO headless browser. The owner must validate the endpoint + its terms of service
# before setting this. Never logged, never sent to the client, never committed.
BAUGESUCHE_ZH_SIGNAL_URL=

# Optional bearer token for the Baugesuche endpoint above (if the official source
# requires one). SERVER-ONLY, never logged, never to the client, never committed.
BAUGESUCHE_ZH_API_KEY=

# -----------------------------------------------------------------------------
# SIMAP public tenders (v0.5.15; endpoints verified v0.5.17.1) — OPTIONAL.
# SERVER-ONLY. Official SIMAP API ONLY — NO scraping/HTML/headless/third-party.
# -----------------------------------------------------------------------------
# The official public project search works WITHOUT a login, so SIMAP works out
# of the box. Defaults (used when these are empty):
#   Base:  https://www.simap.ch
#   Path:  POST /publications/v2/project/project-search
# Only override if the official Swagger lists a different path for your account
# (e.g. behind /api). Results are capped + time-bounded and filtered to
# Clean24-relevant services. Test the connection in Einstellungen → Lead-Quellen.
SIMAP_API_BASE_URL=
# Override the project-search path only if needed (default above).
SIMAP_SEARCH_PATH=
# Optional canton filter (orderAddressCantons), comma-separated, e.g. "ZH,AG".
SIMAP_CANTONS=
# OPTIONAL auth for restricted deployments (public search needs none): EITHER a
# static token OR OAuth client-credentials. Never commit real credentials —
# configure in Vercel → Production env.
SIMAP_API_TOKEN=
SIMAP_API_CLIENT_ID=
SIMAP_API_CLIENT_SECRET=
SIMAP_AUTH_URL=
SIMAP_SCOPE=

# -----------------------------------------------------------------------------
# ZEFIX commercial register (v0.5.15; endpoints verified v0.5.17.1) — OPTIONAL.
# SERVER-ONLY. Official ZEFIX PublicREST API ONLY — NO scraping/bulk download.
# -----------------------------------------------------------------------------
# Official base (default when ZEFIX_API_BASE_URL is empty):
#   https://www.zefix.admin.ch/ZefixPublicREST
#   Company search: POST /api/v1/company/search  (name min. 3 chars, + canton)
# The OpenAPI security scheme is HTTP BASIC ("Zefix-Credentials"), so REAL
# CREDENTIALS ARE REQUIRED — set ZEFIX_API_USERNAME + ZEFIX_API_PASSWORD
# (recommended ZEFIX_AUTH_MODE=basic). Without them ZEFIX shows "Zugang
# erforderlich". A bearer token is supported only if your deployment uses one.
# Never commit real credentials — configure in Vercel → Production env.
ZEFIX_API_BASE_URL=
ZEFIX_API_USERNAME=
ZEFIX_API_PASSWORD=
# Optional: force the auth method ("basic" recommended, the official scheme;
# "token" only for bearer setups). If empty, Klarsa uses basic when a
# username/password is present.
ZEFIX_AUTH_MODE=
# Optional bearer token (only if your ZEFIX access uses one instead of basic).
ZEFIX_API_TOKEN=
# Optional canton filter for company search, e.g. "ZH".
ZEFIX_CANTON=

# -----------------------------------------------------------------------------
# Outreach send channel (v0.5.9) — OPTIONAL, owner-configured. SERVER-ONLY.
# -----------------------------------------------------------------------------
# Controlled, single-recipient, owner-approved EMAIL sending (Premium only).
# Uses the official Resend REST API (https://api.resend.com/emails) — no SMTP
# library, no new dependency. If unset, the Outreach Autopilot shows "Kanal nicht
# verbunden" and the send button is disabled (drafts stay copy-only). This is NOT
# mass mailing: one selected message to one recipient per explicit click, no bulk,
# no scheduled/background send, no WhatsApp. Cold-outreach stays blocked.
#
# Resend API key. SERVER-ONLY — never NEXT_PUBLIC_, never sent to the browser,
# never logged, never committed.
RESEND_API_KEY=

# Verified sender address for outbound mail, e.g. "Klarsa <kontakt@ihre-domain.ch>"
# or "kontakt@ihre-domain.ch". Must be a domain/address verified in Resend. The
# owner is responsible for sender identity + opt-out compliance.
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Send provider selection (v0.5.10) — OPTIONAL.
# -----------------------------------------------------------------------------
# Which send channel to use: "resend" or "smtp". If empty, Resend is used when
# configured, otherwise SMTP. SERVER-ONLY.
OUTREACH_SEND_PROVIDER=

# -----------------------------------------------------------------------------
# SMTP send channel (v0.5.10) — OPTIONAL, owner-configured. SERVER-ONLY.
# -----------------------------------------------------------------------------
# Send from a real mailbox (e.g. info@clean-24.ch) over SMTP via nodemailer.
# Same controlled, single-recipient, owner-approved sending as Resend — no bulk,
# no schedule, no background send. Set OUTREACH_SEND_PROVIDER=smtp to use it.
# Never NEXT_PUBLIC_, never logged, never committed.
SMTP_HOST=
# Common ports: 465 (implicit TLS) or 587 (STARTTLS).
SMTP_PORT=
# "true" for implicit TLS (port 465). If empty, derived from the port.
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
# Sender address, e.g. "Clean24 <info@clean-24.ch>" or "info@clean-24.ch".
SMTP_FROM=

# -----------------------------------------------------------------------------
# IMAP inbox channel (v0.5.10 foundation) — OPTIONAL, owner-configured.
# SERVER-ONLY. Reads incoming replies. v0.5.10 only DETECTS configuration and
# shows status ("Antwort-Erkennung über IMAP vorbereitet"); it does NOT connect,
# poll, or import any mail yet (reply tracking is v0.5.11, owner-triggered).
# Never NEXT_PUBLIC_, never logged, never committed.
INBOX_PROVIDER=
IMAP_HOST=
IMAP_PORT=
IMAP_SECURE=
IMAP_USER=
IMAP_PASSWORD=
# Mailbox to read replies from later (default "INBOX").
IMAP_MAILBOX=

# -----------------------------------------------------------------------------
# Follow-up sequence cron (v0.5.16) — OPTIONAL. SERVER-ONLY.
# -----------------------------------------------------------------------------
# Shared secret for the PREPARED follow-up heartbeat endpoint
# (app/api/cron/followups/route.ts). If unset, the endpoint returns 404
# (invisible). Even when set, the endpoint performs NO sending: background
# cross-tenant processing would require a service-role identity, which is
# intentionally NOT used. Real follow-up sends are OWNER-TRIGGERED in-app
# (Premium + configured provider, capped, audited). To schedule the heartbeat
# on Vercel, add a `vercel.json` cron entry pointing at /api/cron/followups.
# Never NEXT_PUBLIC_, never logged, never sent to the client, never committed.
FOLLOWUP_CRON_SECRET=
