# Klarsa Core — environment template (STAGING)
# =============================================================================
# This is a TEMPLATE with PLACEHOLDERS ONLY. Copy it to `.env.local` and fill in
# real values there. `.env.local` is git-ignored and must NEVER be committed.
#
#   cp .env.local.example .env.local
#
# Rules:
#   - NEVER commit a real `.env.local` (no URLs, keys, refs, passwords).
#   - The SERVICE ROLE key is SERVER-ONLY: it bypasses Row Level Security.
#     Never expose it to the browser, never prefix it with NEXT_PUBLIC_,
#     never log it.
#   - Only NEXT_PUBLIC_* values are safe to ship to the client.
#   - Use a STAGING project here. NO production data in staging.
# =============================================================================

# Supabase project URL (e.g. https://<project-ref>.supabase.co)
# Public/client-safe.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key. Client-safe; RLS still applies to it.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key. SERVER-ONLY. Bypasses RLS — treat as a top secret.
# Never NEXT_PUBLIC_, never sent to the browser, never logged.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project ref (the <project-ref> part of the URL). Used by the CLI.
SUPABASE_PROJECT_REF=

# Klarsa environment marker. Keep "staging" until production is approved.
KLARSA_ENV=staging

# -----------------------------------------------------------------------------
# Automatic Discovery (v0.5.2) — OPTIONAL, owner-configured.
# -----------------------------------------------------------------------------
# Google Places API key for the OFFICIAL Places Text Search adapter
# (lib/discovery/google-places.ts). SERVER-ONLY — never NEXT_PUBLIC_, never sent
# to the browser, never logged, never committed. If unset, Automatic Discovery
# shows "not configured" and the app keeps working. Owner/admin-triggered only;
# no cron. Official API only — NO scraping of Google Maps pages/HTML.
GOOGLE_PLACES_API_KEY=

# Shared secret for the PREPARED discovery/signal cron endpoint
# (app/api/autopilot/discovery-cron/route.ts). SERVER-ONLY. If unset, the
# endpoint returns 404 (invisible). Even when set, the endpoint is DISABLED by
# design and performs NO writes — scheduled tenant writes would need a
# service-role identity, which is intentionally not used. There is no vercel.json
# cron entry, so nothing is scheduled.
CRON_SECRET=

# Baugesuche Zürich signal source (v0.5.4). OPTIONAL, owner-configured.
# SERVER-ONLY. URL of a *validated* OFFICIAL building-permit / construction-project
# open-data JSON endpoint (e.g. an opendata.swiss / Kanton Zürich / Stadt Zürich
# dataset or an OGC API Features / GeoJSON feed). If unset, the Baugesuche adapter
# shows "not configured" and the app keeps working. Official JSON API ONLY —
# NO website scraping, NO HTML/PDF parsing, NO headless browser. The owner must
# validate the endpoint + its terms of service before setting this. Never logged,
# never sent to the client, never committed.
BAUGESUCHE_ZH_SIGNAL_URL=

# Optional bearer token for the Baugesuche endpoint above (if the official source
# requires one). SERVER-ONLY, never logged, never to the client, never committed.
BAUGESUCHE_ZH_API_KEY=
